      <div class="code-block">
        <pre set:html={`<span class="cd">// consent.js verified consent GRANTED
// Worker fires all strategies simultaneously</span>

<span class="cb">const</span> <span class="co">strategies</span> = [
  <span class="cg">new MetaStrategy</span>(<span class="co">env.META_PIXEL_ID</span>),
  <span class="cg">new GoogleStrategy</span>(<span class="co">env.GA4_MEASUREMENT_ID</span>),
  <span class="cg">new TikTokStrategy</span>(<span class="co">env.TIKTOK_PIXEL_ID</span>),
  <span class="cg">new ClickHouseStrategy</span>(<span class="co">env.CLICKHOUSE_URL</span>),
  <span class="cd">// Add your own strategy —</span>
  <span class="cd">// Snowflake, BigQuery, Amplitude...</span>
  <span class="cd">// anything that takes an HTTP request</span>
];

<span class="cb">await</span> Promise.all(
  strategies.map(s => s.execute(event))
);

<span class="cd">// Credentials: your CF env vars only
// Attestrack runs in your account — no vendor holds destination secrets
// No third-party data sharing
// Ad-blocker resistant — first-party domain
// ITP immune — server-side, no cookies</span>`} />
