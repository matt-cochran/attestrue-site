---
import Base from '@layouts/Base.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const canonical = new URL('/blog/', Astro.site ?? 'https://attestrue.com');
---

<Base
  title="Blog — Attestrue"
  description="Updates and notes on Attestrue: product, trust chain, and how it extends the open-source Attestrack stack."
  canonical={canonical}
>
  <Nav />
  <main class="blog-index">
    <div class="blog-index-inner">
      <header class="page-header">
        <h1>Blog</h1>
        <p class="intro">Markdown-backed posts on Attestrue and first-party proof. Open-source Attestrack lives at <a href="https://attestrack.com">attestrack.com</a>.</p>
      </header>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`} class="post-card">
              <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .blog-index {
    padding: 48px 0 80px;
  }
  .blog-index-inner {
    max-width: 40rem;
    margin: 0 auto;
    padding: 0 48px;
  }
  .page-header {
    margin-bottom: 40px;
  }
  .page-header h1 {
    font-family: var(--serif);
    font-size: clamp(36px, 4vw, 48px);
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  .intro {
    font-size: 17px;
    font-weight: 300;
    color: var(--ink-4);
    line-height: 1.55;
  }
  .intro a {
    color: var(--red);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .post-card {
    display: block;
    padding: 24px;
    border: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .post-card:hover {
    border-color: var(--ink-3);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }
  .post-card time {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-5);
  }
  .post-card h2 {
    font-family: var(--serif);
    font-size: 22px;
    margin: 10px 0 8px;
    color: var(--ink);
  }
  .post-card p {
    font-size: 15px;
    font-weight: 300;
    color: var(--ink-4);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .blog-index-inner {
      padding: 0 24px;
    }
  }
</style>
