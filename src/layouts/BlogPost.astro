---
import Base from './Base.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate } = post.data;
const canonical = new URL(`/blog/${post.slug}/`, Astro.site ?? 'https://attestrue.com');
---

<Base title={`${title} — Attestrack`} description={description} canonical={canonical}>
  <Nav />
  <main class="blog-post">
    <article class="blog-inner">
      <header class="post-header">
        <p class="meta">
          <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          {updatedDate && (
            <>
              {' · '}
              <span>Updated <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
            </>
          )}
        </p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
      </header>
      <div class="prose">
        <slot />
      </div>
      <p class="back"><a href="/blog/">← All posts</a></p>
    </article>
  </main>
  <Footer />
</Base>

<style>
  .blog-post {
    padding: 48px 0 80px;
  }
  .blog-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 0 48px;
  }
  .post-header {
    margin-bottom: 36px;
  }
  .post-header .meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-5);
    margin-bottom: 12px;
  }
  .post-header h1 {
    font-family: var(--serif);
    font-size: clamp(32px, 4vw, 44px);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .post-header .lede {
    font-size: 17px;
    font-weight: 300;
    color: var(--ink-4);
    line-height: 1.55;
  }
  .prose {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-3);
  }
  .prose :global(h2) {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--ink);
    margin: 32px 0 14px;
  }
  .prose :global(p) {
    margin-bottom: 16px;
  }
  .prose :global(ul) {
    margin: 16px 0;
    padding-left: 1.25rem;
  }
  .prose :global(li) {
    margin-bottom: 8px;
  }
  .prose :global(a) {
    color: var(--red);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(strong) {
    font-weight: 500;
    color: var(--ink);
  }
  .back {
    margin-top: 48px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.05em;
  }
  .back a {
    color: var(--red);
    text-decoration: none;
  }
  .back a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .blog-inner {
      padding: 0 24px;
    }
  }
</style>
